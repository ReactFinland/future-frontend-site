{
  "name": "future-frontend-site",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "node --env-file=.env ./node_modules/gustwind/cli.js --build --output ./build",
    "build:clean": "node ./scripts/build.mjs",
    "start": "node --env-file=.env ./node_modules/gustwind/cli.js --develop --port 3000",
    "serve": "node --env-file=.env ./node_modules/gustwind/cli.js --serve --input ./build --port 3000",
    "optimize:build": "jampack ./build"
  },
  "dependencies": {
    "@divriots/jampack": "0.34.1",
    "esbuild": "0.25.10",
    "gray-matter": "4.0.3",
    "gustwind": "0.96.0",
    "highlight.js": "11.3.1",
    "leaflet": "1.9.4",
    "marked": "9.1.5",
    "url-join": "5.0.0",
    "vite": "7.3.2"
  }
}
