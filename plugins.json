{
  "plugins": [
    {
      "path": "./node_modules/gustwind/plugins/meta/mod.js",
      "options": { "inputPath": "./site/meta.json" }
    },
    {
      "path": "./node_modules/gustwind/routers/config-router/mod.js",
      "options": {
        "dataSourcesPath": "./site/dataSources.ts",
        "routesPath": "./site/routes.json"
      }
    },
    {
      "path": "./site/plugins/htmlispRenderer.ts",
      "options": {
        "components": [
          { "path": "./site/components" },
          { "path": "./site/layouts" }
        ],
        "globalUtilitiesPath": "./site/globalUtilities.ts"
      }
    },
    {
      "path": "./node_modules/gustwind/plugins/copy/mod.js",
      "options": {
        "inputPath": "./assets",
        "outputPath": "./"
      }
    },
    {
      "path": "./node_modules/gustwind/plugins/script/mod.js",
      "options": {
        "scripts": [
          {
            "type": "text/javascript",
            "src": "https://cdn.jsdelivr.net/npm/sidewind@8.0.0/dist/sidewind.umd.production.min.js"
          }
        ],
        "scriptsPath": ["./site/scripts"]
      }
    },
    {
      "path": "./node_modules/gustwind/plugins/sitemap/mod.js"
    },
    {
      "path": "./node_modules/gustwind/plugins/stats/mod.js"
    }
  ]
}
